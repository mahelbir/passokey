{
  "BaseUrl": "https://auth.example.com",
  "AppName": "Passokey",
  "Session": {
    "IdleTimeoutMinutes": 1440,
    "AuthorizedClientLifetimeMinutes": 1440,
    "AdminSessionLifetimeMinutes": 60
  },
  "Fido2": {
    "ServerDomain": "example.com",
    "ServerName": "Passokey",
    "Origins": [],
    "TimestampDriftTolerance": 300000,
    "UserVerification": "Required"
  },
  "Jwt": {
    "TokenLifetimeMinutes": 5
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data/passokey.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Error",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "AllowedHosts": "*"
}
